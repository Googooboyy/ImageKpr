.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# PHP
vendor/
composer.lock
*.log

# Environment
.env
.env.local
.env.*.local

# user folders - redundant
import-export-folders/*
import-export-folders

# tasks folders - for devs
_tasks/
_tasks/*