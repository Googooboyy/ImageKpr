# Deny HTTP access to the root secrets file only.
# Do not use <Files "config.php"> — on Apache that matches every path named config.php,
# including admin/config.php (Phase 12 admin UI).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^config\.php$ - [F,L]
</IfModule>

# Same-origin app uses cookie sessions; avoid wildcard CORS. Re-enable narrowly if you embed APIs on another origin.

# Caching for images
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=2592000, public"
  </IfModule>
</FilesMatch>

# Prevent PHP execution in uploads and inbox
<IfModule mod_setenvif.c>
  SetEnvIf Request_URI "^/images/" no_php
  SetEnvIf Request_URI "^/inbox/" no_php
</IfModule>
